PORT=5000
API_KEY=dev-transchecker-key-change-in-production
MONTHLY_CHAR_LIMIT=500000

# Primary translation engine (recommended for production)
# Get a key: https://cloud.google.com/translate/docs/setup
GOOGLE_TRANSLATE_API_KEY=

# Optional — defaults to GOOGLE_TRANSLATE_API_KEY if empty
GOOGLE_SPEECH_API_KEY=

WHISPER_MODEL=Xenova/whisper-base
